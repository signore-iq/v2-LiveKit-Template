# OpenAI API Key (required for voice agent)
OPENAI_API_KEY=sk-your-openai-api-key

# LiveKit credentials (auto-generated for Railway, set manually for local dev)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Agent fallback mode when room does not specify one: "pipeline" or "realtime"
AGENT_MODE=pipeline
